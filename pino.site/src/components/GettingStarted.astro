<script is:inline>
 // Helper to copy setup commands
 window.copySnippet = function (btn, text) {
  navigator.clipboard.writeText(text).then(() => {
   const orig = btn.innerText;
   btn.innerText = "Copied!";
   setTimeout(() => (btn.innerText = orig), 1500);
  });
 };
</script>

