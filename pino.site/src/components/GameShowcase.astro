<section id="games" class="max-w-6xl mx-auto my-20 px-8">
 <div class="section-header">
  <h2 class="font-heading text-4xl font-bold mb-4">Terminal Gaming Station</h2>
  <p class="text-text-muted text-lg max-w-[600px] mx-auto">
   Pino is designed with excellent ergonomics for building rich, interactive CLI
   and terminal-based RPGs. Experience lightweight development with rapid
   watch-reloads.
  </p>
 </div>

 <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 my-12">
  <!-- Game 1 -->
  <div
   class="bg-bg-secondary border border-border-colored rounded-2xl p-8 transition-all duration-300 hover:(-translate-y-1.5 border-accent-green/30 shadow-[0_15px_35px_rgba(16,185,129,0.1)]) flex flex-col relative overflow-hidden group"
  >
   <span class="game-badge">Dungeon Crawler</span>
   <h3 class="font-heading text-xl font-bold mb-3 text-text-main">
    PinoQuest: The Compiler Core
   </h3>
   <p class="text-text-muted text-[0.92rem] leading-relaxed mb-6 flex-grow">
    A retro compiler crawler. Battle syntax bugs, compiler warnings, and memory
    leaks as you navigate the compiler depths in Easy, Medium, Hard, or Infinite
    crawler modes.
   </p>
   <div
    class="bg-black/20 border border-border-colored rounded-lg p-3 flex justify-between items-center text-accent-green font-mono text-xs"
   >
    <code>pino run pino-csharp/main.pino</code>
    <button
     class="btn-copy-small bg-transparent hover:bg-white/8 text-text-muted hover:text-text-main px-2 py-1 rounded text-[0.75rem] transition"
     onclick="copySnippet(this, 'pino run pino-csharp/main.pino')">Copy</button
    >
   </div>
  </div>

  <!-- Game 2 -->
  <div
   class="bg-bg-secondary border border-border-colored rounded-2xl p-8 transition-all duration-300 hover:(-translate-y-1.5 border-accent-green/30 shadow-[0_15px_35px_rgba(16,185,129,0.1)]) flex flex-col relative overflow-hidden group"
  >
   <span class="game-badge">Simulation / Space RPG</span>
   <h3 class="font-heading text-xl font-bold mb-3 text-text-main">
    StarPino Odyssey
   </h3>
   <p class="text-text-muted text-[0.92rem] leading-relaxed mb-6 flex-grow">
    Warp between star systems, mine rich asteroid fields, upgrade your ship,
    escape pirate interceptors, and buy the Sol Station Warp Core in a deep
    space simulator.
   </p>
   <div
    class="bg-black/20 border border-border-colored rounded-lg p-3 flex justify-between items-center text-accent-green font-mono text-xs"
   >
    <code>pino play star_pino</code>
    <button
     class="btn-copy-small bg-transparent hover:bg-white/8 text-text-muted hover:text-text-main px-2 py-1 rounded text-[0.75rem] transition"
     onclick="copySnippet(this, 'pino play star_pino')">Copy</button
    >
   </div>
  </div>

  <!-- Game 3 -->
  <div
   class="bg-bg-secondary border border-border-colored rounded-2xl p-8 transition-all duration-300 hover:(-translate-y-1.5 border-accent-green/30 shadow-[0_15px_35px_rgba(16,185,129,0.1)]) flex flex-col relative overflow-hidden group"
  >
   <span class="game-badge">Turn-Based RPG</span>
   <h3 class="font-heading text-xl font-bold mb-3 text-text-main">
    Jade Temple: Path of the Spirit Fist
   </h3>
   <p class="text-text-muted text-[0.92rem] leading-relaxed mb-6 flex-grow">
    A narrative martial arts RPG. Walk the Open Palm or Closed Fist alignment
    path, make reason/intimidate checks in a murder mystery, and wage strategic
    Chi battles.
   </p>
   <div
    class="bg-black/20 border border-border-colored rounded-lg p-3 flex justify-between items-center text-accent-green font-mono text-xs"
   >
    <code>pino play jade_temple</code>
    <button
     class="btn-copy-small bg-transparent hover:bg-white/8 text-text-muted hover:text-text-main px-2 py-1 rounded text-[0.75rem] transition"
     onclick="copySnippet(this, 'pino play jade_temple')">Copy</button
    >
   </div>
  </div>

  <!-- Game 4 -->
  <div
   class="bg-bg-secondary border border-border-colored rounded-2xl p-8 transition-all duration-300 hover:(-translate-y-1.5 border-accent-green/30 shadow-[0_15px_35px_rgba(16,185,129,0.1)]) flex flex-col relative overflow-hidden group"
  >
   <span class="game-badge">Tactical Sci-Fi Simulator</span>
   <h3 class="font-heading text-xl font-bold mb-3 text-text-main">
    SABLE: Semillas de Obsidiana
   </h3>
   <p class="text-text-muted text-[0.92rem] leading-relaxed mb-6 flex-grow">
    A tactical sci-fi RPG set in Halo's Fall of Reach. Allocate resources,
    battle neural fragmentation, and balance civilian survival with protocol
    guidelines. (A creative collaboration between Antigravity & DeepSeek!)
   </p>
   <div
    class="bg-black/20 border border-border-colored rounded-lg p-3 flex justify-between items-center text-accent-green font-mono text-xs"
   >
    <code>pino play sable</code>
    <button
     class="btn-copy-small bg-transparent hover:bg-white/8 text-text-muted hover:text-text-main px-2 py-1 rounded text-[0.75rem] transition"
     onclick="copySnippet(this, 'pino play sable')">Copy</button
    >
   </div>
  </div>
 </div>

 <!-- Quick Play / Installer Guide -->
 <div
  class="bg-gradient-to-r from-accent-cyan/4 to-accent-purple/4 border border-accent-cyan/15 rounded-2xl p-10 shadow-lg flex flex-col gap-8"
 >
  <div class="quick-play-info">
   <h3
    class="font-heading text-2xl font-bold mb-2 bg-gradient-to-r from-accent-cyan to-accent-purple bg-clip-text text-transparent"
   >
    How to Download & Play
   </h3>
   <p class="text-text-muted text-[0.95rem]">
    Start gaming on your terminal in seconds. The Pino compiler features an
    interactive games menu with an automatic cloud downloader.
   </p>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
   <div
    class="flex gap-5 items-start bg-white/2 border border-border-colored p-6 rounded-xl"
   >
    <span
     class="font-heading text-2xl font-bold text-accent-cyan bg-accent-cyan/10 w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0"
     >1</span
    >
    <div>
     <strong class="text-text-main text-[1rem] block mb-1"
      >Open Games Menu</strong
     >
     <p class="text-text-muted text-[0.88rem] leading-relaxed">
      Run <code>pino play</code> in your terminal. If the games library isn't local,
      Pino prompts you to download it.
     </p>
    </div>
   </div>
   <div
    class="flex gap-5 items-start bg-white/2 border border-border-colored p-6 rounded-xl"
   >
    <span
     class="font-heading text-2xl font-bold text-accent-cyan bg-accent-cyan/10 w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0"
     >2</span
    >
    <div>
     <strong class="text-text-main text-[1rem] block mb-1"
      >Update Instantly</strong
     >
     <p class="text-text-muted text-[0.88rem] leading-relaxed">
      Fetch the newest game updates and community levels anytime using the <code
       >pino play update</code
      > downloader command.
     </p>
    </div>
   </div>
   <div
    class="flex gap-5 items-start bg-white/2 border border-border-colored p-6 rounded-xl"
   >
    <span
     class="font-heading text-2xl font-bold text-accent-cyan bg-accent-cyan/10 w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0"
     >3</span
    >
    <div>
     <strong class="text-text-main text-[1rem] block mb-1"
      >Rapid Watch Iteration</strong
     >
     <p class="text-text-muted text-[0.88rem] leading-relaxed">
      Make your own games! Run <code>pino watch [file]</code>. The daemon
      live-reloads the interpreter instantly on save.
     </p>
    </div>
   </div>
  </div>
 </div>
</section>
