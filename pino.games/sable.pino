struct Sector {
  name string
  civilians int
  evacuated int
  danger int
  seed_name string
  seed_size int
  seed_progress int
  seed_archived bool
}

struct SableState {
  fragmentation int
  civilians_saved int
  civilians_lost int
  seeds_archived int
  cpu_pool int
  ram_pool int
  ram_max int
  turn int
  zero_allocation_count int
}

fn corrupt_text(text string, level int) {
  if level < 15 {
    return text
  }
  
  var result = ""
  val length = text:len
  val symbols = ["▒", "░", "█", "Ø", "▲", "§", "æ", "▰", "▱", "▮", "▯", "◊", "♦", "#", "@", "?", "*", "!", "%", "&"]
  
  for i in length {
    val roll = rand(100)
    if roll < (level / 2) {
      val sym_idx = rand(20)
      val sym = symbols[sym_idx]
      result = result + sym
    } else {
      result = result + text[i]
    }
  }
  
  return result
}

fn print_glitched(text string, level int) {
  val corrupted = corrupt_text(text, level)
  println(corrupted)
}

fn draw_sable(fragmentation int) {
  var eye = "o"
  if fragmentation >= 80 {
    eye = "#"
  } else if fragmentation >= 40 {
    eye = "x"
  }
  
  println("      /\\___/\\ ")
  println("     /  $eye   $eye  \\    [SABLE: Zorro de Obsidiana]")
  println("    (  = ^ =  )         [Fragmentación: $fragmentation%]")
  println("     )       (")
  println("    /         \\ ")
  println("   /   \\   /   \\ ")
  println("  (_____)_____)")
}

fn show_hud(sable SableState, sectors []Sector) {
  clear()
  println("==========================================================================")
  println("                 SABLE: PROTOCOLO SEMILLA - CICLO $(sable:turn)/7")
  println("                       \"Semillas de Obsidiana\"")
  println("==========================================================================")
  println("")
  
  draw_sable(sable:fragmentation)
  println("")
  println(" ESTADO DE SABLE:")
  println("   - Núcleo de CPU    : $(sable:cpu_pool) ciclos")
  println("   - Memoria RAM      : $(sable:ram_pool) GB")
  println("   - Almas Salvadas   : $(sable:civilians_saved) civiles")
  println("   - Almas Perdidas   : $(sable:civilians_lost) civiles")
  println("   - Semillas en Safe : $(sable:seeds_archived)/4 descargadas")
  println("--------------------------------------------------------------------------")
  println(" ESTADO DE LOS SECTORES:")
  
  for i in 4 {
    val s = sectors[i]
    if s:danger >= 100 {
      println("  $(i+1). [CALCINADO] $(s:name) | 🟥 Peligro: 100% | Semilla: DESTRUIDA")
    } else {
      val remaining = s:civilians - s:evacuated
      var seed_status = "Descargando ($(s:seed_progress)/$(s:seed_size))"
      if s:seed_archived {
        seed_status = "💾 ARCHIVADA"
      }
      println("  $(i+1). $(s:name)")
      println("     - Civiles  : $remaining restantes (Evacuados: $(s:evacuated)/$(s:civilians))")
      println("     - Peligro  : $(s:danger)%")
      println("     - Semilla  : $(s:seed_name) [$seed_status]")
    }
  }
  println("==========================================================================")
}

