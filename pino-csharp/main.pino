struct People {
  name string
  country string
}

val people = map[string, People] {
  "A": People { name: "Shawn", country: "MX" }
  "B": People { name: "Alice", country: "MX" }
  "C": People { name: "Bob", country: "MX" }
}
val list = [1, 2, 3]

for index, number in list {
  println(index, number)
}

for id, person in people {
  println(id, person)
}