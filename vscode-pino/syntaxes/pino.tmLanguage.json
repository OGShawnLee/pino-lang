{
  "name": "Pino",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#function-calls"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.pino",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.pino",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.pino",
              "match": "\\\\."
            },
            {
              "name": "variable.other.readwrite.pino",
              "match": "\\$[a-zA-Z_$][a-zA-Z0-9_$]*"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.pino",
          "match": "\\b(if|then|else|match|when|for|in|return|break|continue)\\b"
        },
        {
          "name": "storage.type.pino",
          "match": "\\b(fn|struct|enum|var|val)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.pino",
          "match": "\\b(int|float|string|bool|any)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.pino",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.pino",
          "match": "\\b[0-9]+(_[0-9]+)*\\.[0-9]+(_[0-9]+)*\\b"
        },
        {
          "name": "constant.numeric.integer.pino",
          "match": "\\b[0-9]+(_[0-9]+)*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.pino",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.operator.comparison.pino",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.pino",
          "match": "(\\+=|-=|\\*=|/=|%=|=)"
        },
        {
          "name": "keyword.operator.arithmetic.pino",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.member.pino",
          "match": "(::|:)"
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.pino"
            }
          }
        }
      ]
    }
  },
  "scopeName": "source.pino"
}
