import Lexer
import Parser

fn main {
  val content = "fn main { return not -(2) }"
  val begin = time()
  val list = Lexer::lex(content)
  val program = Parser::parse(list)
  val end = time()

  match program {
    when Result::Success(program) {
      program:print()
    }
    when Result::Failure(error) {
      println("Unable to Parse: $error")
    }
  }

  println("Processed in $(end - begin) ms")
}